{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "星枢OpenClaw",
  "version": "4.3.5",
  "identifier": "ai.openclaw.tulu-openclaw-v2",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "星枢OpenClaw",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "resizable": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "appimage",
      "deb",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/player.html",
      "player.html",
      "../src/player.html",
      "resources/Star-Office-UI-master/**/*",
      "resources/agency-agents/**/*",
      "resources/cli-anything/**/*",
      "resources/codex提示词/**/*",
      "resources/runtime/**/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "languages": [
          "SimpChinese",
          "TradChinese",
          "English"
        ],
        "displayLanguageSelector": true,
        "installerHooks": "./windows/nsis-installer-hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "preInstallScript": "./linux/close-running-app.sh",
        "preRemoveScript": "./linux/close-running-app.sh"
      }
    }
  }
}
